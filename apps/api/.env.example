# Copy to .env for local development. Never commit real .env values.
#
# Local Docker Compose defaults. For Cloud SQL, replace every value with
# deployment-provided secrets/placeholders from README.md.
DATABASE_URL=postgresql+asyncpg://linko:linko@localhost:5432/linko
ALEMBIC_DATABASE_URL=postgresql+psycopg://linko:linko@localhost:5432/linko
TEST_DATABASE_URL=postgresql+asyncpg://linko:linko@localhost:5432/linko_test

# Issue #7 feature flags.
PERSON_REQUIRED=false
IDEMPOTENCY_TTL_SECONDS=86400
