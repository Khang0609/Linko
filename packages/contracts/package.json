{
  "name": "@linko/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "test": "vitest run && pnpm run check:openapi",
    "export:openapi": "cd ../../apps/api && uv run python scripts/export_openapi.py --output ../../packages/contracts/openapi.json",
    "check:openapi": "cd ../../apps/api && uv run python scripts/export_openapi.py --output ../../packages/contracts/openapi.json --check",
    "generate": "pnpm run export:openapi && openapi-ts"
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
