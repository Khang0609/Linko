    op.create_index("idx_offers_intent", "offers", ["intent_type"])
    op.create_index("idx_needs_business", "needs", ["business_id"])
    op.create_index("idx_needs_intent", "needs", ["intent_type"])
    op.create_index("idx_offers_attrs", "offers", ["structured_attrs"], postgresql_using="gin")
    op.create_index("idx_needs_attrs", "needs", ["structured_attrs"], postgresql_using="gin")
    op.create_index("idx_offers_geo", "offers", ["geo_scope"], postgresql_using="gin")
    op.create_index("idx_needs_geo", "needs", ["geo_scope"], postgresql_using="gin")
    # Partial unique: at most 1 NULL role per business-person pair (Postgres: NULL ≠ NULL)
    op.execute(
        "CREATE UNIQUE INDEX uq_business_person_null_role "
        "ON business_persons (business_id, person_id) WHERE role IS NULL;"
    )

    # ===== Trigger updated_at (DB-level, runs even when bypassing ORM) =====
    op.execute("""
        CREATE OR REPLACE FUNCTION set_updated_at()
        RETURNS TRIGGER AS $$
        BEGIN NEW.updated_at = NOW(); RETURN NEW; END;
        $$ LANGUAGE plpgsql;
    """)
    for tbl in ("businesses", "persons", "offers", "needs"):
        op.execute(f"""
            CREATE TRIGGER trg_{tbl}_updated_at
            BEFORE UPDATE ON {tbl}
            FOR EACH ROW EXECUTE FUNCTION set_updated_at();
        """)


def downgrade() -> None:
    # Drop triggers + function
    for tbl in ("businesses", "persons", "offers", "needs"):
        op.execute(f"DROP TRIGGER IF EXISTS trg_{tbl}_updated_at ON {tbl}")
    op.execute("DROP FUNCTION IF EXISTS set_updated_at()")
    # ### commands auto generated by Alembic - please adjust! ###
    op.drop_table('match_interactions')
    op.drop_table('offers')
    op.drop_table('needs')
    op.drop_table('business_persons')
    op.drop_table('businesses')
    op.drop_table('persons')
    op.drop_table('intent_types')
    op.drop_table('industries')
    op.drop_table('certifications')
    # ### end Alembic commands ###

    # Drop extensions
    op.execute("DROP EXTENSION IF EXISTS google_ml_integration")
    op.execute("DROP EXTENSION IF EXISTS unaccent")
    op.execute("DROP EXTENSION IF EXISTS vector")
