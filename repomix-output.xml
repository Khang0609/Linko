  User,
  Lock,
  Building2,
  Shield,
  TrendingUp,
  Brain,
  ChevronRight,
  Link2,
  Network,
} from "lucide-react";
import { AreaChart, Area, ResponsiveContainer } from "recharts";

const connectionsData = [
  { v: 820 },
